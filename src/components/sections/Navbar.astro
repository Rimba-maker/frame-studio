---
const navLinks = [
  { label: 'Work', href: '#portfolio' },
  { label: 'Services', href: '#services' },
  { label: 'Studio', href: '#studio' },
  { label: 'Clients', href: '#clients' },
  { label: 'Journal', href: '#journal' },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  data-scrolled="false"
>
  <nav class="max-w-[1600px] mx-auto px-6 md:px-10 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group" aria-label="Frame Studio">
      <div class="w-5 h-5 border border-white/80 rotate-45 group-hover:rotate-[135deg] transition-transform duration-500"></div>
      <span class="text-white text-[15px] font-medium tracking-[-0.02em]">Frame Studio</span>
    </a>

    <!-- Nav links — desktop -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-[14px] text-[#a7a7a7] hover:text-white transition-colors duration-200 tracking-[-0.01em]"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <div class="flex items-center gap-4">
      <a
        href="#contact"
        class="hidden md:inline-flex items-center gap-2 px-5 py-2 text-[13px] font-medium tracking-[0.02em] uppercase border border-white/20 text-white hover:bg-white hover:text-black transition-all duration-200 rounded-[4px]"
      >
        Get Quote
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden flex flex-col gap-[5px] p-1"
        aria-label="Open menu"
      >
        <span class="w-5 h-px bg-white block transition-all duration-300"></span>
        <span class="w-5 h-px bg-white block transition-all duration-300"></span>
        <span class="w-3 h-px bg-white block transition-all duration-300 ml-auto"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-black border-t border-[#27272a]"
  >
    <ul class="flex flex-col px-6 py-6 gap-5">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-[16px] text-[#a7a7a7] hover:text-white transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-5 py-2.5 text-[13px] font-medium tracking-[0.02em] uppercase border border-white/20 text-white hover:bg-white hover:text-black transition-all duration-200 rounded-[4px]"
        >
          Get Quote
        </a>
      </li>
    </ul>
  </div>
</header>

<!-- Spacer so content doesn't hide behind fixed navbar -->
<div class="h-16"></div>

<script>
  const navbar = document.getElementById('navbar') as HTMLElement;
  const mobileBtn = document.getElementById('mobile-menu-btn') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;

  // Scroll: add bg on scroll
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 20;
    if (scrolled) {
      navbar.style.backgroundColor = 'rgba(0,0,0,0.9)';
      navbar.style.backdropFilter = 'blur(12px)';
      navbar.style.borderBottom = '1px solid #27272a';
    } else {
      navbar.style.backgroundColor = 'transparent';
      navbar.style.backdropFilter = 'none';
      navbar.style.borderBottom = 'none';
    }
  });

  // Mobile toggle
  let open = false;
  mobileBtn.addEventListener('click', () => {
    open = !open;
    mobileMenu.classList.toggle('hidden', !open);
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      open = false;
      mobileMenu.classList.add('hidden');
    });
  });
</script>
